# ═══════════════════════════════════════════════════════════════
# NAUTICAL NICK — Environment variables
# ═══════════════════════════════════════════════════════════════
# Copy to `.env` locally for dev. In production, set these in
# Railway's "Variables" tab (do NOT commit the real .env file).

# ── Server ───────────────────────────────────────────────────
# Your public domain. Used in emails + checkout redirects.
BASE_URL=https://nauticalnick.net

# Port — Railway assigns automatically in production. For local
# dev, the server defaults to 3000 if this is unset.
# PORT=3000

# ── Stripe (payments) ────────────────────────────────────────
# Find it: dashboard.stripe.com → Developers → API keys.
# Use sk_test_* for testing, sk_live_* for production.
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY

# The Price ID (NOT Product ID) of your Premium subscription.
# Find it: Stripe dashboard → Products → your product → pricing section,
# the row shows "price_...". Use that.
STRIPE_PRICE_ID=price_REPLACE_WITH_YOUR_PRICE_ID

# Webhook signing secret.
# Find it: Stripe dashboard → Developers → Webhooks → your endpoint →
# "Signing secret" (starts with whsec_).
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_SECRET

# ── Resend (email) ───────────────────────────────────────────
# Find it: resend.com → API Keys.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Must be on a domain you've verified in Resend.
FROM_EMAIL=alerts@nauticalnick.net

# ── Anthropic (daily AI summary + pier cam vision) ──────────
# Find it: console.anthropic.com → API Keys.
# Used by the scripts/ pipeline — runs on GitHub Actions, NOT
# on Railway. Set it as a GitHub repository secret there.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxx

# ── NASA Earthdata (satellite chlorophyll fallback #3) ──────
# Used by scripts/fetch-satellite.js. Set as GitHub repo secrets.
NASA_EARTHDATA_USER=your-earthdata-username
NASA_EARTHDATA_PASS=your-earthdata-password

# ── Auth & sessions ──────────────────────────────────────────
# Where the user/session JSON DB lives. On Railway, mount a
# persistent Volume at this path or sessions reset on deploy.
# Default (if unset): ./data-runtime
# DATA_DIR=/data

# Cross-origin frontend? Set this to the allowed origin(s)
# comma-separated. Leave unset if Express serves the static site
# same-origin (current setup).
# CORS_ORIGIN=https://nauticalnick.net
