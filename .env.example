# ═══════════════════════════════════════════════════════════════
# NAUTICAL NICK — Environment variables
# ═══════════════════════════════════════════════════════════════
# Copy to `.env` locally for dev. In production, set these in
# Railway's "Variables" tab (do NOT commit the real .env file).

# ── Server ───────────────────────────────────────────────────
# Your public domain. Used in emails + checkout redirects.
BASE_URL=https://nauticalnick.net

# Port — Railway assigns automatically in production. For local
# dev, the server defaults to 3000 if this is unset.
# PORT=3000

# ── Stripe (payments) ────────────────────────────────────────
# Find it: dashboard.stripe.com → Developers → API keys.
# Use sk_test_* for testing, sk_live_* for production.
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY

# The Price ID (NOT Product ID) of your Premium subscription.
# Find it: Stripe dashboard → Products → your product → pricing section,
# the row shows "price_...". Use that.
STRIPE_PRICE_ID=price_REPLACE_WITH_YOUR_PRICE_ID

# Webhook signing secret.
# Find it: Stripe dashboard → Developers → Webhooks → your endpoint →
# "Signing secret" (starts with whsec_).
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_SECRET

# ── Resend (email) ───────────────────────────────────────────
# Find it: resend.com → API Keys.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Must be on a domain you've verified in Resend.
FROM_EMAIL=alerts@nauticalnick.net

# ── Anthropic (daily AI summary + pier cam vision) ──────────
# Find it: console.anthropic.com → API Keys.
# Used by the scripts/ pipeline — runs on GitHub Actions, NOT
# on Railway. Set it as a GitHub repository secret there.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxx

# ── NASA Earthdata (satellite chlorophyll fallback #3) ──────
# Used by scripts/fetch-satellite.js. Set as GitHub repo secrets.
NASA_EARTHDATA_USER=your-earthdata-username
NASA_EARTHDATA_PASS=your-earthdata-password

# ── Auth & sessions ──────────────────────────────────────────
# Where the user/session JSON DB lives. On Railway, mount a
# persistent Volume at this path or sessions reset on deploy.
# Default (if unset): ./data-runtime
# DATA_DIR=/data

# Cross-origin frontend? Set this to the allowed origin(s)
# comma-separated. Leave unset if Express serves the static site
# same-origin (current setup).
# CORS_ORIGIN=https://nauticalnick.net

# ═══════════════════════════════════════════════════════════════
# PHASE 0 — Next.js migration additions (migration/next branch)
# ═══════════════════════════════════════════════════════════════
# These are required for the Next.js + Prisma + Stripe stack on
# the migration/next branch. Until cutover, the vanilla main
# branch on Railway production does not need these set.

# ── Postgres (Railway-managed) ───────────────────────────────
# Railway provisions a Postgres plugin and exposes DATABASE_URL
# automatically to linked services. For local dev, point at a
# local Postgres or Railway's public connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/nautical_nick

# ── NextAuth / session signing ───────────────────────────────
# Random 32+ byte secret used to sign session cookies / tokens.
# Generate: `openssl rand -base64 32`
NEXTAUTH_SECRET=replace_with_openssl_rand_base64_32

# ── Stripe (test mode for migration/next) ────────────────────
# Use test-mode keys on the migration branch — production STRIPE_*
# vars above continue to drive live payments on main until cutover.
# STRIPE_SECRET_KEY above is reused; below are the additional IDs
# needed by the new monthly + annual plan structure.
STRIPE_PRICE_ID_MONTHLY=price_test_REPLACE_WITH_MONTHLY_PRICE_ID
STRIPE_PRICE_ID_ANNUAL=price_test_REPLACE_WITH_ANNUAL_PRICE_ID

# Webhook signing secret for the Next.js /api/stripe/webhook
# route on the migration preview environment. Distinct from the
# production STRIPE_WEBHOOK_SECRET above.
# (Re-uses the same env var name — set the test value on the
#  migration/next Railway environment, the live value on prod.)
# STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_TEST_SECRET

# ── Phase 1 additions ────────────────────────────────────────
# Two Pro price IDs — the /api/stripe/checkout route takes
# { plan: "monthly" | "annual" } and selects the matching var.
# (STRIPE_PRICE_ID_MONTHLY + STRIPE_PRICE_ID_ANNUAL are already
#  declared above in the "Stripe (test mode)" block.)

# Session cookie name — optional override (defaults to naut_session)
# SESSION_COOKIE_NAME=naut_session

# Public app URL used in Stripe success/cancel redirects.
# TEMPORARY: set to the Railway preview URL while migration/next
# is the active branch. At cutover, swap to https://nauticalnick.net
# on the production Railway environment.
NEXT_PUBLIC_APP_URL=https://nautical-nick-visibility-report-migration.up.railway.app
