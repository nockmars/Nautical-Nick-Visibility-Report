{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "outDir": "./.ts-scripts-out"
  },
  "include": [
    "scripts/**/*.ts",
    "lib/data/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "scripts/__tests__/**",
    "lib/data/__tests__/**"
  ]
}
