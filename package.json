{
  "name": "nautical-nick-visibility-report",
  "version": "1.0.0",
  "description": "Daily ocean visibility tracker for San Diego spearfishermen",
  "main": "api/server.js",
  "scripts": {
    "start": "next start",
    "start:vanilla": "node api/server.js",
    "dev": "next dev",
    "build": "next build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "capture": "node scripts/capture-pier-cam.js",
    "satellite": "node scripts/fetch-satellite.js",
    "surf": "node scripts/fetch-surf.js",
    "scrape": "node scripts/scrape-justgetwet.js",
    "summary": "node scripts/generate-summary.js",
    "alerts": "node scripts/send-alerts.js",
    "update": "node scripts/update-all.js",
    "satellite:ts": "tsx scripts/fetchers/fetch-satellite.ts",
    "surf:ts": "tsx scripts/fetchers/fetch-surf.ts",
    "weather:ts": "tsx scripts/fetchers/fetch-weather.ts",
    "scrape:ts": "tsx scripts/scrapers/scrape-justgetwet.ts",
    "capture:ts": "tsx scripts/captures/capture-pier-cam.ts",
    "update:ts": "tsx scripts/update-all.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "argon2": "^0.44.0",
    "body-parser": "^1.20.2",
    "cookie": "^1.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "next": "^15.5.15",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^4.0.0",
    "stripe": "^17.0.0",
    "uuid": "^9.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "prisma": "^6.19.3",
    "puppeteer": "^22.8.0",
    "tailwindcss": "^4.2.4",
    "ts-jest": "^29.2.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "testMatch": [
      "**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs",
            "moduleResolution": "node"
          }
        }
      ]
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "collectCoverageFrom": [
      "lib/**/*.ts",
      "app/api/**/*.ts"
    ]
  }
}
